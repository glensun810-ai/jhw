/**
 * 错误显示组件样式
 * 
 * P2-4 优化：可复用组件 - 显示错误信息和操作建议
 */

.error-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 错误图标 */
.error-icon-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.error-icon {
  font-size: 60rpx;
}

/* 错误标题 */
.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

/* 错误描述 */
.error-description {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

/* 错误详情 */
.error-detail {
  background-color: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
  width: 100%;
}

.error-detail-text {
  font-size: 24rpx;
  color: #999;
  word-break: break-all;
}

/* 操作按钮 */
.error-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
}

.error-action-btn {
  min-width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.error-action-btn.primary {
  background-color: #007aff;
  color: #fff;
}

.error-action-btn:not(.primary) {
  background-color: #f5f5f5;
  color: #333;
}
