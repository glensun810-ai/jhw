/* 综合评分仪表盘组件样式 */

.score-gauge-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
}

.gauge-wrapper {
  position: relative;
  width: 400rpx;
  height: 200rpx;
  overflow: hidden;
}

/* 仪表盘背景 */
.gauge-bg {
  position: absolute;
  width: 400rpx;
  height: 200rpx;
  transform-origin: center bottom;
}

.gauge-segment {
  width: 100%;
  height: 100%;
  border-radius: 200rpx 200rpx 0 0;
  opacity: 0.3;
}

/* 指针 */
.gauge-pointer {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 8rpx;
  height: 180rpx;
  transform-origin: center bottom;
  transition: transform 0.5s ease-out;
  z-index: 10;
}

.pointer-tip {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 24rpx solid #4A7BFF;
}

.pointer-base {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  background: #4A7BFF;
  border-radius: 50%;
}

/* 中心分数 */
.gauge-center {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 5;
}

.center-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #333;
  font-family: 'DIN', 'Arial', sans-serif;
  line-height: 1;
}

.center-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.center-grade {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.center-grade.grade-excellent {
  color: #00F5A0;
  background: rgba(0, 245, 160, 0.1);
}

.center-grade.grade-good {
  color: #f39c12;
  background: rgba(243, 156, 18, 0.1);
}

.center-grade.grade-fair {
  color: #3498db;
  background: rgba(52, 152, 219, 0.1);
}

.center-grade.grade-poor {
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
}

.center-grade.grade-pending {
  color: #999;
  background: rgba(153, 153, 153, 0.1);
}

/* 刻度标签 */
.gauge-labels {
  display: flex;
  justify-content: space-between;
  width: 400rpx;
  margin-top: 20rpx;
}

.gauge-label {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label-value {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

.label-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* 评分详情 */
.gauge-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  width: 100%;
  margin-top: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(74, 123, 255, 0.05);
  border-radius: 12rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #4A7BFF;
  font-family: 'DIN', 'Arial', sans-serif;
}
