/* 词云组件样式 */

.word-cloud-container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
}

.chart-header {
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.chart-subtitle {
  font-size: 24rpx;
  color: #999;
}

.cloud-body {
  padding: 20rpx 0;
  min-height: 300rpx;
}

/* 词云标签 */
.cloud-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  align-items: center;
}

.tag-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-text {
  font-weight: 600;
  line-height: 1.3;
}

.tag-count {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 列表模式 */
.list-mode {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.list-rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
}

.rank-num.top3 {
  background: linear-gradient(135deg, #4A7BFF, #6B94FF);
  color: #fff;
}

.list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.list-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.list-bar {
  width: 120rpx;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
