/* 信源列表组件样式 */

.source-list-container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.list-body {
  height: 600rpx;
}

.source-scroll {
  height: 100%;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.source-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  gap: 20rpx;
}

.source-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.source-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.source-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.source-authority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.source-authority.authority-high {
  background: rgba(0, 245, 160, 0.15);
  color: #00F5A0;
}

.source-authority.authority-medium {
  background: rgba(243, 156, 18, 0.15);
  color: #f39c12;
}

.source-authority.authority-low {
  background: rgba(153, 153, 153, 0.15);
  color: #999;
}

.source-url {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.source-stats {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-end;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A7BFF;
}

.stat-value.risk-high {
  color: #e74c3c;
}

.stat-value.risk-medium {
  color: #f39c12;
}

.stat-value.risk-low {
  color: #00F5A0;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
