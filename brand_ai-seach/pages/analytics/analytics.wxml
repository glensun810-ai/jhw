<!--
  统计分析页面 - 产品架构优化版
  多维度数据分析，支持战略决策
-->
<view class="analytics-container">
  <!-- 空状态 -->
  <view wx:if="{{!hasData}}" class="empty-state">
    <image class="empty-icon" src="/assets/icons/empty-analytics.png" mode="aspectFit" />
    <text class="empty-title">暂无分析数据</text>
    <text class="empty-desc">完成至少 1 次品牌诊断后即可查看分析报告</text>
    <text class="empty-desc">当前诊断记录：{{diagnosisCount}} 条</text>
    <button class="go-diagnose" bindtap="goToDiagnosis">去诊断</button>
  </view>

  <!-- 正常内容 -->
  <view wx:else class="content">
    <!-- 页面头部 -->
    <view class="page-header">
      <text class="page-title">统计分析</text>
      <text class="page-subtitle">多维度数据分析，支持战略决策</text>
    </view>

    <!-- 筛选栏 -->
    <view class="filter-bar">
      <!-- 品牌筛选 -->
      <picker
        class="filter-picker"
        mode="selector"
        range="{{brandOptions}}"
        range-key="label"
        value="{{brandIndex}}"
        bindchange="onBrandChange"
      >
        <view class="picker-display">
          <text class="picker-icon">🏷️</text>
          <text class="picker-text">{{brandOptions[brandIndex].label}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>

      <!-- 时间范围筛选 -->
      <picker
        class="filter-picker"
        mode="selector"
        range="{{timeRangeOptions}}"
        range-key="label"
        value="{{timeRangeIndex}}"
        bindchange="onTimeRangeChange"
      >
        <view class="picker-display">
          <text class="picker-icon">📅</text>
          <text class="picker-text">{{timeRangeOptions[timeRangeIndex].label}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>

      <!-- 重置筛选 -->
      <view class="filter-reset" bindtap="resetFilters">
        <text class="reset-icon">🔄</text>
        <text class="reset-text">重置</text>
      </view>
    </view>

    <!-- 激活的筛选条件标签 -->
    <view class="active-filters" wx:if="{{hasActiveFilters}}">
      <view class="filter-tag" wx:if="{{selectedBrand !== 'all'}}">
        <text class="tag-text">品牌：{{selectedBrandLabel}}</text>
        <text class="tag-close" bindtap="clearBrandFilter">×</text>
      </view>
      <view class="filter-tag" wx:if="{{timeRange !== 'all'}}">
        <text class="tag-text">时间：{{timeRangeLabel}}</text>
        <text class="tag-close" bindtap="clearTimeRangeFilter">×</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <scroll-view class="tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="tabs-container">
        <view 
          class="tab-item {{currentTab === item.id ? 'active' : ''}}"
          wx:for="{{analysisTabs}}"
          wx:key="id"
          wx:for-item="item"
          bindtap="onTabChange"
          data-tab-id="{{item.id}}"
        >
          <text class="tab-icon">{{item.icon}}</text>
          <text class="tab-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 内容区域 -->
    <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="content-wrapper">
        
        <!-- 品牌对比 -->
        <view wx:if="{{currentTab === 'brand'}}" class="tab-content">
          <view class="section-intro">
            <text class="intro-title">品牌综合评分对比</text>
            <text class="intro-desc">基于所有诊断记录的品牌平均分对比</text>
          </view>

          <view class="section-actions">
            <view class="action-btn" bindtap="goToBrandDimension">
              <text class="btn-icon">📊</text>
              <text class="btn-text">详细分析</text>
            </view>
          </view>

          <bar-chart
            data="{{brandCompareData}}"
            title=""
            color="#4A7BFF"
          />

          <view class="data-tips">
            <text class="tip-title">💡 数据解读</text>
            <text class="tip-content">• 柱状图高度代表品牌综合评分</text>
            <text class="tip-content">• 评分越高表示 AI 认知越好</text>
            <text class="tip-content">• 建议关注评分较低的品牌</text>
          </view>
        </view>

        <!-- 趋势分析 -->
        <view wx:if="{{currentTab === 'trend'}}" class="tab-content">
          <view class="section-intro">
            <text class="intro-title">品牌声量趋势</text>
            <text class="intro-desc">最近 10 次诊断的声量份额变化</text>
          </view>
          
          <line-chart 
            data="{{trendData}}"
            title=""
            color="#00F5A0"
          />
          
          <view class="data-tips">
            <text class="tip-title">💡 数据解读</text>
            <text class="tip-content">• 折线图展示声量份额变化趋势</text>
            <text class="tip-content">• 上升趋势表示 AI 曝光增加</text>
            <text class="tip-content">• 下降趋势需要关注优化</text>
          </view>
        </view>

        <!-- AI 平台对比 -->
        <view wx:if="{{currentTab === 'platform'}}" class="tab-content">
          <view class="section-intro">
            <text class="intro-title">AI 平台认知差异</text>
            <text class="intro-desc">不同 AI 平台的品牌认知对比</text>
          </view>
          
          <radar-chart 
            data="{{platformData}}"
            title=""
            color="#4A7BFF"
          />
          
          <view class="data-tips">
            <text class="tip-title">💡 数据解读</text>
            <text class="tip-content">• 雷达图展示各维度得分</text>
            <text class="tip-content">• 面积越大表示认知越好</text>
            <text class="tip-content">• 关注得分较低的维度</text>
          </view>
        </view>

        <!-- 问题聚合 -->
        <view wx:if="{{currentTab === 'question'}}" class="tab-content">
          <view class="section-intro">
            <text class="intro-title">高频问题 TOP10</text>
            <text class="intro-desc">被问及最多的问题排行</text>
          </view>
          
          <word-cloud 
            data="{{questionData}}"
            title=""
            subtitle="TOP10"
            showList="{{true}}"
          />
          
          <view class="data-tips">
            <text class="tip-title">💡 数据解读</text>
            <text class="tip-content">• TOP 问题反映用户关注点</text>
            <text class="tip-content">• 建议针对性优化内容</text>
            <text class="tip-content">• 关注负面问题及时处理</text>
          </view>
        </view>

      </view>
    </scroll-view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>
