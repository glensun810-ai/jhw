<!--
  历史记录页面 - 专业版（与项目整体风格统一）
  
  深色主题配色：
  - 主背景：#121826
  - 卡片背景：#1A202C
  - 边框色：#303030
  - 主文字：#e8e8e8
  - 强调色：#00E5FF
-->

<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-content">
      <view class="header-left">
        <text class="page-title">历史诊断报告</text>
        <text class="page-subtitle">回顾并追踪您的品牌 AI 认知演变</text>
      </view>
      <view class="header-right">
        <button class="icon-btn" bindtap="enterBatchMode" wx:if="{{!batchMode}}">
          <text class="icon">✓</text>
          <text class="btn-text">批量</text>
        </button>
        <button class="icon-btn cancel" bindtap="exitBatchMode" wx:if="{{batchMode}}">
          <text class="icon">✕</text>
          <text class="btn-text">取消</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-area">
    <!-- 统计信息卡片 - 产品架构优化版 -->
    <view class="stats-section" wx:if="{{!batchMode}}">
      <view class="stats-card">
        <view class="stat-item" bindtap="onStatTap" data-type="total">
          <view class="stat-value primary">{{stats.total}}</view>
          <view class="stat-label">总记录</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="completed">
          <view class="stat-value success">{{stats.completed}}</view>
          <view class="stat-label">已完成</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="average">
          <view class="stat-value warning">{{stats.averageScore}}</view>
          <view class="stat-label">平均分</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="onStatTap" data-type="favorited">
          <view class="stat-value favorite">{{stats.favorited}}</view>
          <view class="stat-label">收藏数</view>
        </view>
      </view>
    </view>

    <!-- 批量操作工具栏 -->
    <view class="batch-toolbar" wx:if="{{batchMode}}">
      <view class="batch-info">
      <text class="selected-count">{{selectedIds.length}}</text>
      <text class="selected-text">项已选择</text>
    </view>
    <view class="batch-actions">
      <button class="batch-btn select-all" bindtap="onSelectAll">
        {{selectAll ? '取消全选' : '全选'}}
      </button>
      <button class="batch-btn delete" bindtap="onBatchDelete" disabled="{{selectedIds.length === 0}}">
        删除
      </button>
    </view>
  </view>

  <!-- 搜索和筛选栏 - 2026-03-13 UI 优化（大师版） -->
  <view class="filter-section" wx:if="{{!batchMode}}">
    <view class="search-bar">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索品牌名称或诊断 ID"
          value="{{searchKeyword}}"
          bindinput="onSearchChange"
          confirm-type="search"
        />
      </view>
    </view>
    <view class="filter-actions">
      <button class="filter-btn" bindtap="toggleFilterPanel">
        <text class="icon">☰</text>
        <text class="btn-text">筛选</text>
      </button>
      <button class="filter-btn {{showSortMenu ? 'active' : ''}}" bindtap="toggleSortMenu">
        <text class="icon">⇅</text>
        <text class="btn-text">排序</text>
      </button>
    </view>

    <!-- 筛选条件标签 -->
    <view class="filter-tags" wx:if="{{hasActiveFilters}}">
      <view class="filter-tag" wx:if="{{filterStatus !== 'all'}}">
        <text>{{getStatusText(filterStatus)}}</text>
        <text class="tag-close" bindtap="clearFilter" data-type="status">×</text>
      </view>
      <view class="filter-tag" wx:if="{{timeRange !== 'all'}}">
        <text>{{getTimeRangeText(timeRange)}}</text>
        <text class="tag-close" bindtap="clearFilter" data-type="timeRange">×</text>
      </view>
      <view class="filter-tag" wx:if="{{filterScore !== 'all'}}">
        <text>{{getScoreText(filterScore)}}</text>
        <text class="tag-close" bindtap="clearFilter" data-type="score">×</text>
      </view>
      <view class="filter-tag" wx:if="{{favoriteStatus !== 'all'}}">
        <text>{{favoriteStatus === 'favorited' ? '已收藏' : '未收藏'}}</text>
        <text class="tag-close" bindtap="clearFilter" data-type="favorite">×</text>
      </view>
      <view class="filter-clear-all" bindtap="clearAllFilters">
        <text>清空筛选</text>
      </view>
    </view>

    <!-- 筛选面板 - 产品架构优化版 -->
    <view class="filter-panel" wx:if="{{showFilterPanel}}">
      <!-- 诊断状态 -->
      <view class="filter-group">
        <text class="filter-label">诊断状态</text>
        <view class="filter-options">
          <view 
            class="filter-option {{filterStatus === 'all' ? 'active' : ''}}"
            bindtap="onFilterStatusTap"
            data-value="all"
          >全部</view>
          <view 
            class="filter-option {{filterStatus === 'completed' ? 'active' : ''}}"
            bindtap="onFilterStatusTap"
            data-value="completed"
          >已完成</view>
          <view 
            class="filter-option {{filterStatus === 'failed' ? 'active' : ''}}"
            bindtap="onFilterStatusTap"
            data-value="failed"
          >失败</view>
          <view 
            class="filter-option {{filterStatus === 'processing' ? 'active' : ''}}"
            bindtap="onFilterStatusTap"
            data-value="processing"
          >处理中</view>
        </view>
      </view>

      <!-- 时间范围 -->
      <view class="filter-group">
        <text class="filter-label">时间范围</text>
        <view class="filter-options">
          <view 
            class="filter-option {{timeRange === 'all' ? 'active' : ''}}"
            bindtap="onTimeRangeTap"
            data-value="all"
          >全部</view>
          <view 
            class="filter-option {{timeRange === 'today' ? 'active' : ''}}"
            bindtap="onTimeRangeTap"
            data-value="today"
          >今天</view>
          <view 
            class="filter-option {{timeRange === 'last7days' ? 'active' : ''}}"
            bindtap="onTimeRangeTap"
            data-value="last7days"
          >近 7 天</view>
          <view 
            class="filter-option {{timeRange === 'last30days' ? 'active' : ''}}"
            bindtap="onTimeRangeTap"
            data-value="last30days"
          >近 30 天</view>
          <view 
            class="filter-option {{timeRange === 'last90days' ? 'active' : ''}}"
            bindtap="onTimeRangeTap"
            data-value="last90days"
          >近 90 天</view>
        </view>
      </view>

      <!-- 综合评分 -->
      <view class="filter-group">
        <text class="filter-label">综合评分</text>
        <view class="filter-options">
          <view 
            class="filter-option {{filterScore === 'all' ? 'active' : ''}}"
            bindtap="onFilterScoreTap"
            data-value="all"
          >全部</view>
          <view 
            class="filter-option {{filterScore === 'excellent' ? 'active' : ''}}"
            bindtap="onFilterScoreTap"
            data-value="excellent"
          >80 分以上</view>
          <view 
            class="filter-option {{filterScore === 'good' ? 'active' : ''}}"
            bindtap="onFilterScoreTap"
            data-value="good"
          >60-79 分</view>
          <view 
            class="filter-option {{filterScore === 'poor' ? 'active' : ''}}"
            bindtap="onFilterScoreTap"
            data-value="poor"
          >60 分以下</view>
        </view>
      </view>

      <!-- 收藏状态 -->
      <view class="filter-group">
        <text class="filter-label">收藏状态</text>
        <view class="filter-options">
          <view 
            class="filter-option {{favoriteStatus === 'all' ? 'active' : ''}}"
            bindtap="onFavoriteStatusTap"
            data-value="all"
          >全部</view>
          <view 
            class="filter-option {{favoriteStatus === 'favorited' ? 'active' : ''}}"
            bindtap="onFavoriteStatusTap"
            data-value="favorited"
          >已收藏</view>
          <view 
            class="filter-option {{favoriteStatus === 'not_favorited' ? 'active' : ''}}"
            bindtap="onFavoriteStatusTap"
            data-value="not_favorited"
          >未收藏</view>
        </view>
      </view>

      <view class="filter-actions-row">
        <button class="clear-filter-btn" bindtap="clearAllFilters">清空筛选</button>
      </view>
    </view>

    <!-- 排序菜单 - 产品架构优化版 -->
    <view class="sort-menu" wx:if="{{showSortMenu}}">
      <view class="sort-item {{sortBy === 'time' && sortOrder === 'desc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="time-desc">
        <text class="sort-icon">🕐</text>
        <text class="sort-text">时间降序</text>
        <text class="check-mark" wx:if="{{sortBy === 'time' && sortOrder === 'desc'}}">✓</text>
      </view>
      <view class="sort-item {{sortBy === 'time' && sortOrder === 'asc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="time-asc">
        <text class="sort-icon">🕐</text>
        <text class="sort-text">时间升序</text>
        <text class="check-mark" wx:if="{{sortBy === 'time' && sortOrder === 'asc'}}">✓</text>
      </view>
      <view class="sort-item {{sortBy === 'score' && sortOrder === 'desc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="score-desc">
        <text class="sort-icon">📊</text>
        <text class="sort-text">分数降序</text>
        <text class="check-mark" wx:if="{{sortBy === 'score' && sortOrder === 'desc'}}">✓</text>
      </view>
      <view class="sort-item {{sortBy === 'score' && sortOrder === 'asc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="score-asc">
        <text class="sort-icon">📊</text>
        <text class="sort-text">分数升序</text>
        <text class="check-mark" wx:if="{{sortBy === 'score' && sortOrder === 'asc'}}">✓</text>
      </view>
      <view class="sort-item {{sortBy === 'brand' && sortOrder === 'asc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="brand-asc">
        <text class="sort-icon">🏷️</text>
        <text class="sort-text">品牌名称 (A-Z)</text>
        <text class="check-mark" wx:if="{{sortBy === 'brand' && sortOrder === 'asc'}}">✓</text>
      </view>
      <view class="sort-item {{sortBy === 'brand' && sortOrder === 'desc' ? 'active' : ''}}" bindtap="onSortByChange" data-value="brand-desc">
        <text class="sort-icon">🏷️</text>
        <text class="sort-text">品牌名称 (Z-A)</text>
        <text class="check-mark" wx:if="{{sortBy === 'brand' && sortOrder === 'desc'}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 历史记录列表 -->
  <scroll-view class="history-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onScrollToLower">
    <view class="history-list" wx:if="{{filteredList.length > 0}}">
      <view
        class="history-card {{batchMode ? 'batch-mode' : ''}} {{selectedIds.includes(item.executionId) ? 'selected' : ''}}"
        wx:for="{{filteredList}}"
        wx:key="executionId"
        bindtap="onReportTap"
        data-execution-id="{{item.executionId}}"
        data-brand-name="{{item.brandName}}"
      >
        <!-- 批量模式选择框 -->
        <view class="card-checkbox" wx:if="{{batchMode}}" catchtap="onItemSelect" data-id="{{item.executionId}}">
          <view class="checkbox {{selectedIds.includes(item.executionId) ? 'checked' : ''}}">
            <text wx:if="{{selectedIds.includes(item.executionId)}}">✓</text>
          </view>
        </view>
        
        <!-- 卡片内容 - 2026-03-13 专业版 -->
        <view class="card-content">
          <view class="card-main">
            <view class="brand-row">
              <text class="brand-name">{{item.brandName}}</text>
              <view class="status-tag {{item.status}}">
                {{item.status === 'completed' ? '已完成' : (item.status === 'failed' ? '失败' : '处理中')}}
              </view>
            </view>
            <view class="info-row">
              <view class="score-section">
                <text class="score-label">综合评分</text>
                <text class="score-value {{item.scoreLevel}}">{{item.overallScore}}</text>
              </view>
              <view class="divider"></view>
              <view class="meta-section">
                <text class="meta-item">
                  <text class="meta-icon">🆔</text>
                  <text>{{item.executionId ? item.executionId.slice(-6) : '0000'}}</text>
                </text>
                <text class="meta-divider">·</text>
                <text class="meta-item">
                  <text class="meta-icon">🕐</text>
                  <text>{{item.formattedTime}}</text>
                </text>
              </view>
            </view>
          </view>
          <view class="card-actions" wx:if="{{!batchMode}}">
            <button
              class="action-icon-btn {{item.isFavorited ? 'favorited' : ''}}"
              bindtap="toggleFavorite"
              data-execution-id="{{item.executionId}}"
              data-brand-name="{{item.brandName}}"
              data-is-favorited="{{item.isFavorited}}"
            >
              <text class="action-icon">{{item.isFavorited ? '★' : '☆'}}</text>
            </button>
            <button class="action-icon-btn more-btn" bindtap="showActionMenu" data-execution-id="{{item.executionId}}" data-brand-name="{{item.brandName}}" data-index="{{index}}">
              <text class="action-icon">⋮</text>
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{isEmpty && !loading}}">
      <view class="empty-content">
        <text class="empty-icon">{{emptyType === 'no_data' ? '📋' : (emptyType === 'network_error' ? '⚠️' : '🔍')}}</text>
        <text class="empty-title">{{emptyType === 'no_data' ? '暂无历史报告' : (emptyType === 'network_error' ? '加载失败' : '未找到匹配结果')}}</text>
        <text class="empty-desc" wx:if="{{emptyType === 'no_data'}}">
          进行一次品牌诊断，生成您的第一份分析报告
        </text>
        <text class="empty-desc" wx:if="{{emptyType === 'no_search_result'}}">
          试试调整筛选条件或更换关键词
        </text>
        <text class="empty-desc" wx:if="{{emptyType === 'network_error'}}">
          请检查网络连接后重试
        </text>
        
        <view class="empty-actions" wx:if="{{emptyType === 'no_data'}}">
          <button class="primary-btn" bindtap="createNewDiagnosis">
            开始诊断
          </button>
        </view>
        
        <button class="retry-btn" bindtap="refreshHistory" wx:if="{{emptyType === 'network_error'}}">
          重新加载
        </button>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading && !refreshing}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载...</text>
    </view>
  </scroll-view>
</view>

  
  <!-- Toast 提示 -->
  <view class="toast {{toast.show ? 'show' : ''}} {{toast.type}}">
    <text class="toast-icon">{{toast.type === 'success' ? '✓' : (toast.type === 'error' ? '✕' : 'ℹ')}}</text>
    <text class="toast-message">{{toast.message}}</text>
  </view>
</view>
