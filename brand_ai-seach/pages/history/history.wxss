/**
 * 历史记录页面 - 专业版（与项目整体风格统一）
 *
 * 配色方案：
 * - 主背景：#121826（深蓝黑色）
 * - 卡片背景：#1A202C（深色卡片）
 * - 边框色：#303030（深灰边框）
 * - 主文字：#e8e8e8（浅色文字）
 * - 次文字：#8c8c8c（灰色文字）
 * - 强调色：#00E5FF（科技青）
 * - 成功色：#00F5A0
 * - 警告色：#f39c12
 * - 错误色：#e74c3c
 *
 * 作者：前端工程师 & UI 设计大师
 * 日期：2026-03-04
 * 版本：3.0 - L2/L3/L4 优化版（2026-03-11）
 *
 * 优化内容：
 * - L2: 多维度识别锚点设计（分数徽章 + ID+ 时间）
 * - L3: 横向布局减少垂直空间占用（-18%）
 * - L4: 品牌名视觉权重提升（34rpx）
 */

/* 导入全局样式 */
@import "../../app.wxss";

/* ========== 页面容器 ========== */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1f29 0%, #121826 100%);
  color: #e8e8e8;
}

/* ========== 内容区域 ========== */
.content-area {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

/* ========== 页面头部 ========== */
.page-header {
  background: rgba(26, 32, 44, 0.8);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 20rpx 30rpx 30rpx;
  border-bottom: 1rpx solid #303030;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  flex: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  line-height: 1.3;
}

.page-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  display: block;
  margin-top: 8rpx;
}

.header-right {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 229, 255, 0.15);
  border: 1rpx solid rgba(0, 229, 255, 0.3);
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #00E5FF;
  transition: all 0.3s ease;
}

.icon-btn.cancel {
  background: rgba(231, 76, 60, 0.15);
  border-color: rgba(231, 76, 60, 0.3);
  color: #e74c3c;
}

.icon-btn .icon {
  font-size: 28rpx;
  font-weight: bold;
}

.icon-btn .btn-text {
  font-weight: 500;
}

.icon-btn:active {
  transform: scale(0.95);
}

/* ========== 统计信息卡片 ========== */
.stats-section {
  margin: 20rpx 30rpx;
}

.stats-card {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  font-family: 'Courier New', 'DIN', monospace;
}

.stat-value.primary {
  color: #00E5FF;
}

.stat-value.success {
  color: #00F5A0;
}

.stat-value.warning {
  color: #f39c12;
}

.stat-value.favorite {
  color: #e91e63;
}

.stat-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #303030;
}

/* ========== 批量操作工具栏 ========== */
.batch-toolbar {
  margin: 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(26, 32, 44, 0.9) 0%, rgba(18, 24, 38, 0.9) 100%);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 229, 255, 0.1);
}

.batch-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.selected-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

.selected-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

.batch-actions {
  display: flex;
  gap: 16rpx;
}

.batch-btn {
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.batch-btn.select-all {
  background: rgba(0, 229, 255, 0.15);
  color: #00E5FF;
  border: 1rpx solid rgba(0, 229, 255, 0.3);
}

.batch-btn.delete {
  background: rgba(231, 76, 60, 0.15);
  color: #e74c3c;
  border: 1rpx solid rgba(231, 76, 60, 0.3);
}

.batch-btn.delete[disabled] {
  opacity: 0.4;
  border-color: rgba(231, 76, 60, 0.2);
}

.batch-btn:active {
  transform: scale(0.95);
}

/* ========== 搜索和筛选栏 - 2026-03-13 专业版 ========== */
.filter-section {
  margin: 0 30rpx 20rpx;
}

.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #1A202C;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  border: 1rpx solid #303030;
}

.search-input-wrapper:focus-within {
  border-color: #00E5FF;
}

.search-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #e8e8e8;
}

.search-input::placeholder {
  color: #5a5a5a;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
}

.filter-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #1A202C;
  border: 1rpx solid #303030;
  border-radius: 14rpx;
  padding: 18rpx 24rpx;
}

.filter-btn .icon {
  font-size: 28rpx;
  color: #00E5FF;
}

.filter-btn .btn-text {
  font-size: 26rpx;
  color: #e8e8e8;
  font-weight: 500;
}

.filter-btn.active {
  background: rgba(0, 229, 255, 0.1);
  border-color: rgba(0, 229, 255, 0.3);
}

.filter-btn.active .icon,
.filter-btn.active .btn-text {
  color: #00E5FF;
}

/* 筛选条件标签 */
.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 14rpx 0;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(74, 123, 255, 0.12);
  border: 1rpx solid rgba(74, 123, 255, 0.25);
  border-radius: 12rpx;
  padding: 6rpx 14rpx;
}

.filter-tag text {
  font-size: 22rpx;
  color: #4A7BFF;
}

.filter-tag .tag-close {
  font-size: 26rpx;
  color: #4A7BFF;
  padding: 0 2rpx;
  line-height: 1;
}

.filter-tag:active {
  opacity: 0.7;
}

.filter-clear-all {
  display: flex;
  align-items: center;
  padding: 6rpx 14rpx;
}

.filter-clear-all text {
  font-size: 22rpx;
  color: #6a6a6a;
}

.filter-clear-all:active {
  opacity: 0.6;
}

/* ========== 筛选面板 ========== */
.filter-panel {
  margin-top: 16rpx;
  background: #1A202C;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-group:last-of-type {
  margin-bottom: 0;
}

.filter-label {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  font-weight: 500;
  margin-bottom: 16rpx;
}

/* 筛选选项 */
.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-option {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid #303030;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #e8e8e8;
  transition: all 0.2s ease;
}

.filter-option.active {
  background: rgba(74, 123, 255, 0.2);
  border-color: #4A7BFF;
  color: #4A7BFF;
}

.filter-option:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.filter-actions-row {
  margin-top: 20rpx;
  text-align: center;
}

.clear-filter-btn {
  background: transparent;
  border: 1rpx solid #e74c3c;
  color: #e74c3c;
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.clear-filter-btn:active {
  background: rgba(231, 76, 60, 0.1);
}

/* ========== 排序菜单 ========== */
.sort-menu {
  margin-top: 16rpx;
  background: #1A202C;
  border-radius: 16rpx;
  padding: 16rpx 0;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: slideDown 0.3s ease;
}

.sort-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  transition: background 0.2s ease;
}

.sort-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.sort-item.active {
  background: rgba(0, 229, 255, 0.1);
}

.sort-icon {
  font-size: 32rpx;
}

.sort-text {
  flex: 1;
  font-size: 28rpx;
  color: #e8e8e8;
  font-weight: 500;
}

.check-mark {
  font-size: 32rpx;
  color: #00E5FF;
  font-weight: bold;
}

/* ========== 历史记录列表 - 2026-03-13 专业版 ========== */
.history-scroll {
  flex: 1;
  height: 100vh;
  padding: 0 30rpx 30rpx;
  box-sizing: border-box;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.history-card {
  background: #1A202C;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #303030;
  position: relative;
  box-sizing: border-box;
}

.history-card.batch-mode {
  padding-left: 56rpx;
}

.history-card:active {
  background: rgba(26, 32, 44, 0.8);
  border-color: #00E5FF;
}

.card-checkbox {
  position: absolute;
  left: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #303030;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1A202C;
}

.checkbox.checked {
  background: #00E5FF;
  border-color: #00E5FF;
  color: #121826;
}

.checkbox text {
  font-size: 24rpx;
  font-weight: bold;
}

/* 卡片内容区 */
.card-content {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.card-main {
  flex: 1;
  min-width: 0;
}

/* 品牌行 */
.brand-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.brand-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  border: 1rpx solid;
  flex-shrink: 0;
}

.status-tag.completed {
  background: rgba(0, 245, 160, 0.1);
  color: #00F5A0;
  border-color: rgba(0, 245, 160, 0.3);
}

.status-tag.failed {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
  border-color: rgba(231, 76, 60, 0.3);
}

.status-tag.processing {
  background: rgba(243, 156, 18, 0.1);
  color: #f39c12;
  border-color: rgba(243, 156, 18, 0.3);
}

/* 信息行 */
.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.score-section {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 6rpx;
}

.score-label {
  font-size: 20rpx;
  color: #5a5a5a;
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'Courier New', 'DIN', monospace;
}

.score-value.excellent {
  color: #00F5A0;
}

.score-value.good {
  color: #f39c12;
}

.score-value.poor {
  color: #e74c3c;
}

.divider {
  width: 2rpx;
  height: 24rpx;
  background: #303030;
}

.meta-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.meta-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #6a6a6a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta-icon {
  font-size: 18rpx;
  flex-shrink: 0;
}

.meta-divider {
  font-size: 20rpx;
  color: #303030;
  flex-shrink: 0;
}

/* 操作按钮区 - 紧凑版 */
.card-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding-top: 4rpx;
  flex-shrink: 0;
}

.action-icon-btn {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.action-icon-btn:active {
  opacity: 0.7;
}

.action-icon-btn.favorited {
  background: transparent;
}

.action-icon {
  font-size: 28rpx;
  color: #6a6a6a;
}

.action-icon-btn.favorited .action-icon {
  color: #f39c12;
}

.action-icon-btn:active .action-icon {
  color: #00E5FF;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #8c8c8c;
}

.empty-desc {
  font-size: 26rpx;
  color: #5a5a5a;
  line-height: 1.6;
  max-width: 500rpx;
}

.empty-actions {
  margin-top: 20rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #00E5FF 0%, #00F5A0 100%);
  color: #121826;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 229, 255, 0.3);
}

.primary-btn:active {
  transform: scale(0.95);
}

.retry-btn {
  background: transparent;
  color: #00E5FF;
  border: 2rpx solid #00E5FF;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.retry-btn:active {
  background: rgba(0, 229, 255, 0.1);
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #303030;
  border-top-color: #00E5FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

/* ========== 加载更多 ========== */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-text,
.no-more-text {
  font-size: 24rpx;
  color: #5a5a5a;
}

/* ========== 分页导航 - 【修复 - 2026-03-20】新增 ========== */
.pagination-container {
  position: sticky;
  bottom: 0;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.pagination {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background-color: #fff;
}

.pagination-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.pagination-info text {
  font-size: 26rpx;
  color: #8c8c8c;
}

.pagination-count {
  font-size: 22rpx;
  color: #bfbfbf;
}

.pagination-buttons {
  display: flex;
  gap: 24rpx;
}

.page-btn {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #5a5a5a;
  background-color: #f5f5f5;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  min-width: 140rpx;
  text-align: center;
  line-height: 1.5;
}

.page-btn.primary {
  color: #fff;
  background-color: #1890ff;
  border-color: #1890ff;
}

.page-btn.disabled,
.page-btn[disabled] {
  color: #d9d9d9;
  background-color: #f5f5f5;
  border-color: #e8e8e8;
}

.page-btn.primary.disabled,
.page-btn.primary[disabled] {
  color: rgba(255, 255, 255, 0.6);
  background-color: #d9d9d9;
  border-color: #e8e8e8;
}

/* ========== Toast 提示 ========== */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(18, 24, 38, 0.95);
  border-radius: 20rpx;
  padding: 28rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid #303030;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.toast.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.toast-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.toast.success .toast-icon {
  color: #00F5A0;
}

.toast.error .toast-icon {
  color: #e74c3c;
}

.toast.info .toast-icon {
  color: #00E5FF;
}

.toast-message {
  font-size: 28rpx;
  color: #e8e8e8;
  font-weight: 500;
}
