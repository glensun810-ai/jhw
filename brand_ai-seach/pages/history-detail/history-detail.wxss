/**
 * 历史记录详情页 - 深色主题统一版
 *
 * 设计理念：
 * - 麦肯锡专业分析风格
 * - 与项目整体深色主题统一
 * - 清晰的信息层级
 * - 舒适的视觉体验
 *
 * 配色方案：
 * - 主背景：#121826（深蓝黑色）
 * - 卡片背景：#1A202C（深色卡片）
 * - 边框色：#303030（深灰边框）
 * - 主文字：#FFFFFF（白色标题）
 * - 次文字：#8c8c8c（灰色说明）
 * - 强调色：#00E5FF（科技青）
 * - 成功色：#00F5A0
 * - 警告色：#f39c12
 * - 错误色：#e74c3c
 *
 * 作者：视觉设计优化项目
 * 日期：2026-03-11
 * 版本：v3.0 - 深色主题统一版
 */

/* 导入全局样式 */
@import "../../app.wxss";

/* 导入组件样式 */
@import "../../components/report/question-wall/question-wall.wxss";
@import "../../components/report/source-list/source-list.wxss";

/* ========== 页面容器 ========== */
.page-container {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a1f29 0%, #121826 100%);
  min-height: 100vh;
  color: #e8e8e8;
}

/* ========== 页面头部 ========== */
.page-header {
  margin-bottom: 30rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left .page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.header-left .page-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
  display: block;
}

.header-right {
  display: flex;
  gap: 16rpx;
}

.favorite-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  border: 1rpx solid #303030;
}

.favorite-icon {
  font-size: 36rpx;
  color: #8c8c8c;
}

.favorite-icon.active {
  color: #e91e63;
}

.more-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  border: 1rpx solid #303030;
}

.more-icon {
  font-size: 32rpx;
  color: #e8e8e8;
}

/* ========== 操作菜单 ========== */
.action-menu {
  background: #1A202C;
  border-radius: 16rpx;
  padding: 16rpx 0;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  transition: background 0.2s ease;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #e8e8e8;
  font-weight: 500;
}

.menu-text.delete {
  color: #e74c3c;
}

/* ========== 综合评分仪表盘 ========== */
.score-gauge-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.score-gauge-section .section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #8c8c8c;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.gauge-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gauge-score {
  font-size: 80rpx;
  font-weight: 700;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
  line-height: 1;
}

.gauge-grade {
  font-size: 32rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  margin-top: 16rpx;
}

.gauge-grade.grade-excellent {
  background: rgba(0, 245, 160, 0.15);
  color: #00F5A0;
  border: 1rpx solid rgba(0, 245, 160, 0.3);
}

.gauge-grade.grade-good {
  background: rgba(243, 156, 18, 0.15);
  color: #f39c12;
  border: 1rpx solid rgba(243, 156, 18, 0.3);
}

.gauge-grade.grade-fair {
  background: rgba(52, 152, 219, 0.15);
  color: #3498db;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
}

.gauge-grade.grade-poor {
  background: rgba(231, 76, 60, 0.15);
  color: #e74c3c;
  border: 1rpx solid rgba(231, 76, 60, 0.3);
}

.gauge-summary {
  font-size: 28rpx;
  color: #8c8c8c;
  margin-top: 16rpx;
  text-align: center;
}

/* ========== 核心指标卡 ========== */
.metrics-section {
  margin-bottom: 30rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  border: 1rpx solid #303030;
}

.metric-label {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 12rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

/* ========== 评分维度 ========== */
.score-dimensions-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.section-title-wrap {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.dimension-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 20rpx;
  border-bottom: 1rpx solid #303030;
}

.dimension-item:last-child {
  border-bottom: none;
}

.dimension-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #8c8c8c;
}

.dimension-bar {
  flex: 1;
  height: 16rpx;
  background: #303030;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.bar-fill.authority {
  background: linear-gradient(90deg, #00E5FF, #00F5A0);
}

.bar-fill.visibility {
  background: linear-gradient(90deg, #00F5A0, #34d399);
}

.bar-fill.purity {
  background: linear-gradient(90deg, #f39c12, #f1c40f);
}

.bar-fill.consistency {
  background: linear-gradient(90deg, #e74c3c, #ff6b6b);
}

.dimension-value {
  width: 80rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

/* ========== 组件区域 ========== */
.component-section {
  margin-bottom: 30rpx;
}

/* ========== 详细结果 ========== */
.detailed-results-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.section-title-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
}

.result-scroll {
  height: 600rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid #303030;
  border-radius: 12rpx;
  padding: 24rpx;
  transition: all 0.3s ease;
}

.result-item:active {
  border-color: #00E5FF;
  background: rgba(0, 229, 255, 0.03);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-brand {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.result-model {
  font-size: 24rpx;
  color: #00E5FF;
  padding: 4rpx 12rpx;
  background: rgba(0, 229, 255, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 229, 255, 0.3);
}

.result-question {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8rpx;
  line-height: 1.5;
}

.result-response {
  font-size: 24rpx;
  color: #5a5a5a;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.result-score-simple {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #303030;
}

.score-label-simple {
  font-size: 24rpx;
  color: #8c8c8c;
}

.score-value-simple {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'Courier New', 'DIN', monospace;
}

.score-value-simple.excellent {
  color: #00F5A0;
}

.score-value-simple.good {
  color: #f39c12;
}

.score-value-simple.poor {
  color: #e74c3c;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  margin-top: 20rpx;
  background: rgba(0, 229, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 229, 255, 0.2);
}

.load-more-text {
  font-size: 26rpx;
  color: #00E5FF;
  font-weight: 600;
}

/* 加载完成 */
.load-complete {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  margin-top: 20rpx;
}

.load-complete-text {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* ========== 底部操作栏 ========== */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 30rpx 0;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.home-btn {
  background: #1A202C;
  color: #8c8c8c;
  border: 1rpx solid #303030;
}

.home-btn:active {
  background: #303030;
  color: #FFFFFF;
}

.history-btn {
  background: transparent;
  color: #00E5FF;
  border: 1rpx solid #00E5FF;
}

.history-btn:active {
  background: rgba(0, 229, 255, 0.1);
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #303030;
  border-top-color: #00E5FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 30rpx;
  color: #8c8c8c;
  font-size: 28rpx;
}

/* ========== 默认值/占位数据弱视觉效果 ========== */
/* 【P21 新增 - 2026-03-15】无真实数据时显示默认值的弱视觉效果 */

/* 浅灰色文字 */
.placeholder-text {
  color: #5a5a5a !important;
  font-style: italic;
  font-weight: 400;
}

/* 浅灰色数字 */
.placeholder-value {
  color: #5a5a5a !important;
  font-style: italic;
  opacity: 0.6;
}

/* 核心指标卡片中的占位值 */
.metrics-section .metric-item.placeholder .metric-value {
  color: #5a5a5a;
  font-style: italic;
  opacity: 0.6;
}

.metrics-section .metric-item.placeholder .metric-label {
  color: #6a6a6a;
}

/* 评分维度条的占位样式 */
.score-dimensions-section .dimension-item.placeholder .dimension-value {
  color: #5a5a5a;
  font-style: italic;
}

.score-dimensions-section .dimension-item.placeholder .bar-fill {
  background: linear-gradient(90deg, #3a3a3a 0%, #2a2a2a 100%);
  opacity: 0.4;
}

/* 综合评分仪表盘的占位样式 */
.score-gauge-section.placeholder .gauge-score {
  color: #5a5a5a;
  font-style: italic;
}

.score-gauge-section.placeholder .gauge-grade {
  color: #5a5a5a;
  opacity: 0.5;
}

.score-gauge-section.placeholder .gauge-summary {
  color: #6a6a6a;
  font-style: italic;
}

/* 信源列表占位样式 */
.source-list.placeholder .source-item {
  opacity: 0.5;
}

.source-list.placeholder .source-name {
  color: #5a5a5a;
  font-style: italic;
}

/* 问题诊断墙占位样式 */
.question-wall.placeholder .risk-item,
.question-wall.placeholder .suggestion-item {
  opacity: 0.4;
  border-left-color: #3a3a3a;
}

.question-wall.placeholder .risk-text,
.question-wall.placeholder .suggestion-text {
  color: #6a6a6a;
  font-style: italic;
}

/* 详细结果列表占位样式 */
.detailed-results-section.placeholder .result-item {
  opacity: 0.5;
  border-color: #2a2a2a;
}

.detailed-results-section.placeholder .result-brand,
.detailed-results-section.placeholder .result-model,
.detailed-results-section.placeholder .question-text,
.detailed-results-section.placeholder .response-text {
  color: #5a5a5a;
  font-style: italic;
}

.detailed-results-section.placeholder .score-value-simple {
  color: #5a5a5a;
  opacity: 0.6;
}

/* 数据不可用提示 */
.data-unavailable {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #5a5a5a;
  font-size: 26rpx;
  font-style: italic;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 12rpx;
  border: 1rpx dashed #3a3a3a;
}

.data-unavailable::before {
  content: '📊';
  margin-right: 12rpx;
  opacity: 0.5;
}
