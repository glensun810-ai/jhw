<!-- 情感对比柱状图组件 -->
<view class="sentiment-bar-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">图表加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!sentimentData || sentimentData.length === 0}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无情感数据</text>
  </view>

  <!-- 图表 -->
  <ec-canvas
    wx:else
    id="sentiment-bar-chart"
    canvas-id="sentiment-bar-chart"
    ec="{{barEc}}"
    style="height: {{height}}px"
  />
</view>
