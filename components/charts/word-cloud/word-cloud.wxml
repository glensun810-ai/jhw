<!--
  词云组件
  用于展示高频问题 TOP10 等
-->
<view class="word-cloud-container">
  <view class="chart-header" wx:if="{{title}}">
    <text class="chart-title">{{title}}</text>
    <text class="chart-subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>
  </view>
  
  <view class="cloud-body">
    <!-- 词云标签 -->
    <view class="cloud-tags">
      <view 
        class="tag-item" 
        wx:for="{{tags}}" 
        wx:key="id"
        wx:for-item="tag"
        style="
          font-size: {{tag.size}}rpx;
          color: {{tag.color}};
          opacity: {{tag.opacity}};
        "
      >
        <text class="tag-text">{{tag.text}}</text>
        <text class="tag-count" wx:if="{{showCount}}">{{tag.count}}</text>
      </view>
    </view>
  </view>
  
  <!-- 列表模式 -->
  <view class="list-mode" wx:if="{{showList}}">
    <view 
      class="list-item" 
      wx:for="{{data}}" 
      wx:key="name"
      wx:for-item="item"
      wx:for-index="index"
    >
      <view class="list-rank">
        <text class="rank-num {{index < 3 ? 'top3' : ''}}">{{index + 1}}</text>
      </view>
      <view class="list-content">
        <text class="list-text">{{item.name}}</text>
        <text class="list-count">{{item.value}}次</text>
      </view>
      <view class="list-bar">
        <view 
          class="bar-fill" 
          style="width: {{(item.value / maxValue * 100)}}%; background: {{index < 3 ? '#4A7BFF' : '#999'}};"
        ></view>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!data || data.length === 0}}">
    <text class="empty-text">暂无数据</text>
  </view>
</view>
