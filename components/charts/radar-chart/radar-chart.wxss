/* 雷达图组件样式 */

.radar-chart-container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
}

.chart-header {
  margin-bottom: 30rpx;
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.chart-body {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

/* 画布容器 */
.canvas-wrapper {
  position: relative;
  width: 500rpx;
  height: 500rpx;
}

/* 背景网格 */
.radar-grid {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
}

.grid-level {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1rpx solid;
  border-radius: 50%;
}

/* 轴线 */
.radar-axes {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
}

.axis-line {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50%;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.1);
  transform-origin: left center;
}

/* 数据区域 */
.radar-data {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

/* 数据点 */
.radar-points {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.data-point {
  position: absolute;
  transform: translate(-50%, -50%);
}

.point-circle {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 标签 */
.radar-labels {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.label-item {
  position: absolute;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

/* 数据列表 */
.data-list {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 8rpx;
}

.data-item .item-name {
  font-size: 26rpx;
  color: #333;
}

.data-item .item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A7BFF;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
