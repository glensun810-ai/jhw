/* 统计分析 - 主页面样式 - 产品架构优化版 */

.analytics-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1f2e 0%, #121826 100%);
  padding-bottom: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-state .empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-state .empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-state .empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.empty-state .go-diagnose {
  margin-top: 60rpx;
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4A7BFF, #6B94FF);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 30rpx 30rpx;
}

.page-header .page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.page-header .page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  display: block;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 0 30rpx 30rpx;
}

.filter-picker {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.filter-picker .picker-display {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 8rpx;
}

.filter-picker .picker-icon {
  font-size: 32rpx;
}

.filter-picker .picker-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.filter-picker .picker-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.filter-reset {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.filter-reset .reset-icon {
  font-size: 32rpx;
}

.filter-reset .reset-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 激活的筛选条件 */
.active-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 30rpx 20rpx;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(74, 123, 255, 0.15);
  border: 1rpx solid rgba(74, 123, 255, 0.3);
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
}

.filter-tag .tag-text {
  font-size: 24rpx;
  color: #4A7BFF;
}

.filter-tag .tag-close {
  font-size: 28rpx;
  color: #4A7BFF;
  padding: 0 4rpx;
}

/* Tab 切换 */
.tabs-scroll {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.tabs-container {
  display: flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.tabs-container .tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.tabs-container .tab-item.active {
  background: rgba(74, 123, 255, 0.15);
}

.tabs-container .tab-item .tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tabs-container .tab-item .tab-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.tabs-container .tab-item.active .tab-name {
  color: #4A7BFF;
  font-weight: 600;
}

/* 内容区域 */
.content-scroll {
  height: calc(100vh - 380rpx);
}

.content-wrapper {
  padding: 0 30rpx;
}

/* Tab 内容 */
.tab-content {
  margin-bottom: 40rpx;
}

/* 章节介绍 */
.section-intro {
  margin-bottom: 30rpx;
}

.section-intro .intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.section-intro .intro-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
}

/* 章节操作按钮 */
.section-actions {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.section-actions .action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(74, 123, 255, 0.15);
  border: 1rpx solid rgba(74, 123, 255, 0.3);
  border-radius: 24rpx;
}

.section-actions .action-btn .btn-icon {
  font-size: 28rpx;
}

.section-actions .action-btn .btn-text {
  font-size: 24rpx;
  color: #4A7BFF;
  font-weight: 600;
}

/* 数据提示 */
.data-tips {
  margin-top: 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.data-tips .tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A7BFF;
  display: block;
  margin-bottom: 16rpx;
}

.data-tips .tip-content {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-mask .loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border: 5rpx solid rgba(74, 123, 255, 0.2);
  border-top-color: #4A7BFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-mask text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #fff;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 页面过渡动画 */
.page-transition {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
