/* pages/history-detail/history-detail.wxss */
/* 与项目整体风格统一的深色主题 */

@import "../../app.wxss";

.page-container {
  padding: 30rpx;
  background: linear-gradient(135deg, #1a1f29 0%, #121826 100%);
  min-height: 100vh;
  color: #e8e8e8;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #303030;
  border-top-color: #00E5FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: #8c8c8c;
  font-size: 28rpx;
}

/* 页面头部 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 10rpx;
}

/* 总体评分卡片 */
.overall-score-section {
  margin-bottom: 30rpx;
}

.score-card {
  background: linear-gradient(135deg, #00E5FF 0%, #00F5A0 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 229, 255, 0.3);
}

.score-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: bold;
  line-height: 1;
  color: #121826;
  font-family: 'Courier New', 'DIN', monospace;
}

.score-grade {
  font-size: 40rpx;
  font-weight: bold;
  margin-left: 20rpx;
  background-color: rgba(18, 24, 38, 0.2);
  padding: 10rpx 30rpx;
  border-radius: 10rpx;
  color: #121826;
}

.score-desc {
  font-size: 28rpx;
  color: #121826;
  opacity: 0.9;
}

/* 评分维度 */
.score-dimensions-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.section-title-wrap {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-left: 10rpx;
}

.dimension-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #303030;
}

.dimension-item:last-child {
  border-bottom: none;
}

.dimension-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #8c8c8c;
}

.dimension-bar {
  flex: 1;
  height: 20rpx;
  background-color: #303030;
  border-radius: 10rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.bar-fill.authority {
  background: linear-gradient(90deg, #00E5FF 0%, #00F5A0 100%);
}

.bar-fill.visibility {
  background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);
}

.bar-fill.purity {
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
}

.bar-fill.consistency {
  background: linear-gradient(90deg, #43e97b 0%, #38f9d7 100%);
}

.dimension-value {
  width: 100rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: bold;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

/* 测试信息 */
.info-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid #303030;
}

.info-label {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 10rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

/* 详细结果列表 */
.detailed-results-section {
  background: #1A202C;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #303030;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.result-list {
  margin-top: 20rpx;
}

.result-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #303030;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.result-brand {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.result-model {
  font-size: 24rpx;
  color: #00E5FF;
  background: rgba(0, 229, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 229, 255, 0.3);
}

.result-question {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.result-response {
  font-size: 24rpx;
  color: #5a5a5a;
  margin-bottom: 20rpx;
  line-height: 1.6;
  background: rgba(0, 0, 0, 0.2);
  padding: 15rpx;
  border-radius: 8rpx;
}

.result-scores {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.result-score-item {
  text-align: center;
}

.score-label {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 6rpx;
}

.score-value {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #00E5FF;
  font-family: 'Courier New', 'DIN', monospace;
}

.result-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #303030;
}

.total-label {
  font-size: 26rpx;
  color: #8c8c8c;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #00F5A0;
  font-family: 'Courier New', 'DIN', monospace;
}

/* 底部操作栏 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  position: sticky;
  bottom: 0;
  background: rgba(18, 24, 38, 0.95);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 1rpx solid #303030;
}

.action-btn {
  flex: 1;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.home-btn {
  background: #1A202C;
  color: #8c8c8c;
  border: 1rpx solid #303030;
}

.home-btn:active {
  background: #303030;
}

.history-btn {
  background: transparent;
  color: #00E5FF;
  border: 1rpx solid #00E5FF;
}

.history-btn:active {
  background: rgba(0, 229, 255, 0.1);
}

.report-btn {
  background: linear-gradient(135deg, #00E5FF 0%, #00F5A0 100%);
  color: #121826;
  box-shadow: 0 8rpx 24rpx rgba(0, 229, 255, 0.3);
}

.report-btn:active {
  transform: scale(0.95);
}

/* 操作菜单 */
.action-menu {
  margin-top: 20rpx;
  background: #1A202C;
  border-radius: 16rpx;
  padding: 16rpx 0;
  border: 1rpx solid #303030;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  transition: background 0.2s ease;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #e8e8e8;
  font-weight: 500;
}

.menu-text.delete {
  color: #e74c3c;
}
