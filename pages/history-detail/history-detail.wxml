<!--
  历史记录详情页 - 性能优化版
  【性能优化 P0 - 2026-03-11】
  1. 使用 wx:if 替代三元表达式
  2. 使用预先计算的 scoreClass
  3. 简化全局变量保存
-->

<view class="page-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载详情中...</text>
  </view>

  <!-- 数据内容 -->
  <view wx:else class="content-wrapper">
    <!-- 页面头部 -->
    <view class="page-header">
      <view class="header-content">
        <view class="header-left">
          <text class="page-title">报告详情</text>
          <text class="page-subtitle">{{brandName}} · {{formattedTime}}</text>
        </view>
        <view class="header-right">
          <view class="favorite-btn" bindtap="toggleFavorite">
            <text class="favorite-icon {{isFavorited ? 'active' : ''}}">★</text>
          </view>
          <view class="more-btn" bindtap="toggleActions">
            <text class="more-icon">⋮</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作菜单 -->
    <view class="action-menu" wx:if="{{showActions}}">
      <view class="menu-item" bindtap="onReDiagnose">
        <text class="menu-icon">🔄</text>
        <text class="menu-text">重新诊断</text>
      </view>
      <view class="menu-item" bindtap="onExportReport">
        <text class="menu-icon">📥</text>
        <text class="menu-text">导出报告</text>
      </view>
      <view class="menu-item" bindtap="onShareAppMessage">
        <text class="menu-icon">📤</text>
        <text class="menu-text">分享报告</text>
      </view>
      <view class="menu-item" bindtap="onDeleteReport">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text delete">删除报告</text>
      </view>
    </view>

    <!-- 综合评分仪表盘 -->
    <view class="score-gauge-section">
      <text class="section-title">综合评分</text>
      <view class="gauge-wrapper">
        <text class="gauge-score">{{overallScore}}</text>
        <text class="gauge-grade {{gradeClass}}">{{overallGrade}}</text>
        <text class="gauge-summary">{{overallSummary}}</text>
      </view>
    </view>

    <!-- 核心指标卡 -->
    <view class="metrics-section" wx:if="{{hasMetrics}}">
      <view class="metrics-grid">
        <view class="metric-item">
          <text class="metric-label">声量份额</text>
          <text class="metric-value">{{sovShare}}%</text>
        </view>
        <view class="metric-item">
          <text class="metric-label">情感得分</text>
          <text class="metric-value">{{sentimentScore}}</text>
        </view>
        <view class="metric-item">
          <text class="metric-label">物理排名</text>
          <text class="metric-value">#{{physicalRank}}</text>
        </view>
        <view class="metric-item">
          <text class="metric-label">影响力</text>
          <text class="metric-value">{{influenceScore}}</text>
        </view>
      </view>
    </view>

    <!-- 评分维度 -->
    <view class="score-dimensions-section">
      <view class="section-title-wrap">
        <text class="section-title">评分维度</text>
      </view>
      <view class="dimension-item">
        <text class="dimension-label">权威度</text>
        <view class="dimension-bar">
          <view class="bar-fill authority" style="width: {{overallAuthority}}%;"></view>
        </view>
        <text class="dimension-value">{{overallAuthority}}分</text>
      </view>
      <view class="dimension-item">
        <text class="dimension-label">可见度</text>
        <view class="dimension-bar">
          <view class="bar-fill visibility" style="width: {{overallVisibility}}%;"></view>
        </view>
        <text class="dimension-value">{{overallVisibility}}分</text>
      </view>
      <view class="dimension-item">
        <text class="dimension-label">纯净度</text>
        <view class="dimension-bar">
          <view class="bar-fill purity" style="width: {{overallPurity}}%;"></view>
        </view>
        <text class="dimension-value">{{overallPurity}}分</text>
      </view>
      <view class="dimension-item">
        <text class="dimension-label">一致性</text>
        <view class="dimension-bar">
          <view class="bar-fill consistency" style="width: {{overallConsistency}}%;"></view>
        </view>
        <text class="dimension-value">{{overallConsistency}}分</text>
      </view>
    </view>

    <!-- 问题诊断墙 -->
    <view class="component-section">
      <question-wall 
        title="问题诊断"
        high-risks="{{highRisks}}"
        medium-risks="{{mediumRisks}}"
        suggestions="{{suggestions}}"
      />
    </view>

    <!-- 信源分析 -->
    <view class="component-section">
      <source-list 
        title="信源分析"
        sources="{{sourceList}}"
      />
    </view>

    <!-- 详细结果列表 -->
    <view class="detailed-results-section">
      <view class="section-title-wrap">
        <text class="section-title">详细测试结果</text>
        <text class="section-subtitle">{{detailedResults.length}}/{{totalResults || 0}} 条记录</text>
      </view>

      <!-- 【P0 修复 - 2026-03-15】移除 enhanced 属性，防止渲染引擎死循环 -->
      <scroll-view class="result-scroll" scroll-y show-scrollbar="{{false}}">
        <view class="result-list">
          <view class="result-item" wx:for="{{detailedResults}}" wx:key="id" wx:for-item="item">
            <view class="result-header">
              <view class="result-brand">{{item.brand}}</view>
              <view class="result-model">{{item.model}}</view>
            </view>
            
            <view class="result-question">
              <text class="question-label">问：</text>
              <text class="question-text">{{item.question}}</text>
            </view>
            
            <!-- 【性能优化 P0】使用 wx:if 切换，避免三元表达式响应式绑定 -->
            <view class="result-response" bindtap="toggleExpand" data-id="{{item.id}}">
              <text class="response-label">答：</text>
              <text class="response-text" wx:if="{{!item.expanded}}">{{item.response}}</text>
              <text class="response-text" wx:else>{{item.fullResponse}}</text>
              
              <text wx:if="{{item.truncated && !item.expanded}}" class="expand-text">... 点击展开</text>
              <text wx:if="{{item.expanded}}" class="collapse-text"> 点击收起</text>
            </view>
            
            <!-- 【性能优化 P0】使用预先计算的 scoreClass -->
            <view class="result-score-simple">
              <text class="score-label-simple">综合评分：</text>
              <text class="score-value-simple {{item.scoreClass}}">{{item.score}}分</text>
            </view>
          </view>
        </view>

        <!-- 加载更多 -->
        <view wx:if="{{hasMoreResults}}" class="load-more" bindtap="loadMoreResults">
          <text class="load-more-text">加载更多 ({{totalResults - detailedResults.length}} 条)</text>
        </view>

        <!-- 已全部加载 -->
        <view wx:if="{{!hasMoreResults && totalResults > 5}}" class="load-complete">
          <text class="load-complete-text">已全部加载</text>
        </view>
      </scroll-view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-actions">
      <button class="action-btn home-btn" bindtap="goHome">返回首页</button>
      <button class="action-btn history-btn" bindtap="viewHistory">返回列表</button>
    </view>
  </view>
</view>
