<!-- GEO 品牌战略诊断看板 - 完整版 (P0 增强版) -->
<!-- 详情抽屉组件 -->
<diagnostic-drawer
  showDrawer="{{showDrawer}}"
  currentQuestionData="{{currentQuestionData}}"
  brandName="{{brandName}}"
  competitors="{{competitors}}"
  bind:close="onDrawerClose"
  bind:save="onDrawerSave"
></diagnostic-drawer>

<!-- 主容器：数据加载成功 -->
<view class="container" wx:if="{{dashboardData}}">
  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-item" bindtap="toggleFavorite">
      <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-item" bindtap="viewHistory">
      <text class="action-icon">📋</text>
      <text class="action-text">历史记录</text>
    </view>
    <view class="action-item" bindtap="shareReport">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
  </view>

  <!-- P0 新增：情报流水线组件 -->
  <view class="pipeline-section" wx:if="{{executionId}}">
    <intelligence-pipeline
      executionId="{{executionId}}"
      brandName="{{dashboardData.summary.brandName}}"
      enableSSE="{{true}}"
      autoScroll="{{true}}"
      collapsed="{{false}}"
      bind:loaded="onPipelineLoaded"
      bind:update="onPipelineUpdate"
      bind:error="onPipelineError"
      bind:itemtap="onPipelineItemTap"
    ></intelligence-pipeline>
  </view>

  <!-- P0 新增：ROI 指标和影响力卡片 -->
  <view class="p0-section" wx:if="{{dashboardData.roi_metrics || dashboardData.impact_scores}}">
    <!-- ROI 指标卡片 -->
    <roi-card
      wx:if="{{dashboardData.roi_metrics}}"
      title="ROI 指标"
      subtitle="投资回报分析"
      roiData="{{dashboardData.roi_metrics}}"
      impactScores="{{dashboardData.impact_scores}}"
      benchmarks="{{dashboardData.benchmarks || defaultBenchmarks}}"
      showDelta="{{true}}"
      showImpact="{{true}}"
      showDetail="{{false}}"
      bind:cardtap="onROICardTap"
    ></roi-card>

    <!-- 影响力仪表盘 -->
    <impact-gauge
      wx:if="{{dashboardData.impact_scores}}"
      impactScores="{{dashboardData.impact_scores}}"
      showInsight="{{true}}"
      title="品牌影响力"
    ></impact-gauge>
  </view>

  <!-- 第一段：概览评分卡片 -->
  <view class="header-card">
    <view class="brand-title">
      <text>{{dashboardData.summary.brandName || '品牌'}} · GEO 品牌诊断报告</text>
      <view class="sov-badge {{dashboardData.summary.sovLabelClass || 'neutral'}}">
        <text class="sov-badge-icon">{{dashboardData.summary.sovLabelClass === 'leading' ? '👑' : dashboardData.summary.sovLabelClass === 'neutral' ? '⚖️' : '📉'}}</text>
        <text class="sov-badge-text">{{dashboardData.summary.sovLabel || '持平'}}</text>
      </view>
    </view>

    <view class="score-section">
      <view class="score-box">
        <text class="score-label">品牌健康度得分</text>
        <text class="score-value {{dashboardData.summary.healthScore >= 80 ? 'excellent' : dashboardData.summary.healthScore >= 60 ? 'good' : 'fair'}}">{{dashboardData.summary.healthScore || 0}}</text>
        <text class="score-unit">分</text>
        <view class="risk-level-badge {{dashboardData.summary.riskLevel || 'safe'}}">
          <text class="risk-level-icon">{{dashboardData.summary.riskLevel === 'critical' ? '🚨' : dashboardData.summary.riskLevel === 'warning' ? '⚠️' : '✅'}}</text>
          <text class="risk-level-text">{{dashboardData.summary.riskLevelText || '低风险'}}</text>
        </view>
      </view>

      <view class="metrics-row">
        <view class="metric-item">
          <view class="metric-value">{{dashboardData.summary.sov || dashboardData.summary.sov_value || 0}}%</view>
          <view class="metric-label">AI 声量占比</view>
          <view class="metric-sub">{{dashboardData.summary.totalMentions || 0}}/{{dashboardData.summary.totalTests || 0}} 提及</view>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <view class="metric-value {{dashboardData.summary.sentimentStatus || 'neutral'}}">{{dashboardData.summary.avgSentiment || dashboardData.summary.sentiment_value || 0}}</view>
          <view class="metric-label">情感均值</view>
          <view class="metric-sub">{{dashboardData.summary.sentimentLabel || '中性'}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 【P1 新增】品牌对比分析 -->
  <view class="section" wx:if="{{brandAnalysis}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📊</text>
        <text class="title-text">品牌对比分析</text>
      </view>
      <view class="section-subtitle">竞争优势对比</view>
    </view>

    <!-- 用户品牌分析 -->
    <view class="brand-analysis-card" wx:if="{{userBrandAnalysis}}">
      <view class="brand-header">
        <text class="brand-name">{{userBrandAnalysis.brand}}</text>
        <view class="brand-badge {{userBrandAnalysis.is_top3 ? 'top3' : 'normal'}}">
          <text class="badge-icon">{{userBrandAnalysis.is_top3 ? '🏆' : '📊'}}</text>
          <text class="badge-text">{{userBrandAnalysis.is_top3 ? 'TOP3' : '普通'}}</text>
        </view>
      </view>

      <view class="brand-metrics">
        <view class="metric">
          <text class="metric-label">提及率</text>
          <text class="metric-value {{userBrandAnalysis.mention_rate >= 0.5 ? 'high' : userBrandAnalysis.mention_rate >= 0.3 ? 'medium' : 'low'}}">{{userBrandAnalysis.mention_rate * 100 || 0}}%</text>
          <text class="metric-sub">{{userBrandAnalysis.mentioned_count || 0}}/{{userBrandAnalysis.total_responses || 0}} 次提及</text>
        </view>

        <view class="metric">
          <text class="metric-label">平均排名</text>
          <text class="metric-value {{userBrandAnalysis.average_rank > 0 && userBrandAnalysis.average_rank <= 3 ? 'good' : userBrandAnalysis.average_rank > 0 ? 'normal' : 'unranked'}}">{{userBrandAnalysis.average_rank > 0 ? userBrandAnalysis.average_rank : '未入榜'}}</text>
          <text class="metric-sub">排名越靠前越好</text>
        </view>

        <view class="metric">
          <text class="metric-label">情感均值</text>
          <text class="metric-value {{userBrandAnalysis.average_sentiment >= 0.3 ? 'positive' : userBrandAnalysis.average_sentiment <= -0.3 ? 'negative' : 'neutral'}}">{{userBrandAnalysis.average_sentiment || 0}}</text>
          <text class="metric-sub">{{userBrandAnalysis.average_sentiment >= 0.3 ? '正面' : userBrandAnalysis.average_sentiment <= -0.3 ? '负面' : '中性'}}</text>
        </view>
      </view>

      <!-- 对比分析 -->
      <view class="comparison-section" wx:if="{{comparison}}">
        <view class="comparison-title">
          <text class="icon">⚖️</text>
          <text class="text">竞争优势</text>
        </view>
        <view class="comparison-content">
          <view class="advantage-item" wx:if="{{comparison.advantages && comparison.advantages.length > 0}}">
            <text class="advantage-label">✨ 优势:</text>
            <text class="advantage-text">{{comparison.advantages.join(', ')}}</text>
          </view>
          <view class="advantage-item" wx:if="{{comparison.disadvantages && comparison.disadvantages.length > 0}}">
            <text class="disadvantage-label">⚠️ 劣势:</text>
            <text class="disadvantage-text">{{comparison.disadvantages.join(', ')}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 竞品分析列表 -->
    <view class="competitor-list" wx:if="{{competitorAnalysis && competitorAnalysis.length > 0}}">
      <view class="list-title">
        <text class="icon">🎯</text>
        <text class="text">竞品分析</text>
      </view>

      <view class="competitor-card" wx:for="{{competitorAnalysis}}" wx:key="brand">
        <view class="competitor-header">
          <text class="competitor-name">{{item.brand}}</text>
          <view class="competitor-badge {{item.is_top3 ? 'top3' : 'normal'}}">
            <text class="badge-icon">{{item.is_top3 ? '🏆' : '📊'}}</text>
            <text class="badge-text">{{item.is_top3 ? 'TOP3' : '普通'}}</text>
          </view>
        </view>

        <view class="competitor-metrics">
          <view class="metric-small">
            <text class="metric-label">提及率</text>
            <text class="metric-value">{{item.mention_rate * 100 || 0}}%</text>
          </view>
          <view class="metric-small">
            <text class="metric-label">平均排名</text>
            <text class="metric-value">{{item.average_rank > 0 ? item.average_rank : '-'}}</text>
          </view>
          <view class="metric-small">
            <text class="metric-label">情感</text>
            <text class="metric-value {{item.average_sentiment >= 0.3 ? 'positive' : item.average_sentiment <= -0.3 ? 'negative' : 'neutral'}}">{{item.average_sentiment || 0}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 【P1 新增】TOP3 竞品榜单 -->
  <view class="section" wx:if="{{top3Brands && top3Brands.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🏆</text>
        <text class="title-text">TOP3 竞品榜单</text>
      </view>
      <view class="section-subtitle">AI 提及率最高</view>
    </view>

    <view class="top3-list">
      <view class="top3-item rank-1" wx:if="{{top3Brands[0]}}">
        <view class="rank-badge">
          <text class="rank-number">1</text>
          <text class="rank-icon">🥇</text>
        </view>
        <view class="brand-info">
          <text class="brand-name">{{top3Brands[0].name || top3Brands[0]}}</text>
          <text class="brand-rank">排名第 {{top3Brands[0].rank || 1}}</text>
        </view>
        <view class="rank-trend">
          <text class="trend-icon">📈</text>
          <text class="trend-text">热门</text>
        </view>
      </view>

      <view class="top3-item rank-2" wx:if="{{top3Brands[1]}}">
        <view class="rank-badge">
          <text class="rank-number">2</text>
          <text class="rank-icon">🥈</text>
        </view>
        <view class="brand-info">
          <text class="brand-name">{{top3Brands[1].name || top3Brands[1]}}</text>
          <text class="brand-rank">排名第 {{top3Brands[1].rank || 2}}</text>
        </view>
        <view class="rank-trend">
          <text class="trend-icon">📊</text>
          <text class="trend-text">稳定</text>
        </view>
      </view>

      <view class="top3-item rank-3" wx:if="{{top3Brands[2]}}">
        <view class="rank-badge">
          <text class="rank-number">3</text>
          <text class="rank-icon">🥉</text>
        </view>
        <view class="brand-info">
          <text class="brand-name">{{top3Brands[2].name || top3Brands[2]}}</text>
          <text class="brand-rank">排名第 {{top3Brands[2].rank || 3}}</text>
        </view>
        <view class="rank-trend">
          <text class="trend-icon">📊</text>
          <text class="trend-text">稳定</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 【P2 新增】品牌对比图表可视化 -->
  <view class="chart-section" wx:if="{{brandAnalysis || competitorAnalysis}}">
    <!-- 竞争优势雷达图 -->
    <view class="chart-card" wx:if="{{userBrandAnalysis && competitorAnalysis && competitorAnalysis.length > 0}}">
      <brand-radar
        title="品牌竞争力雷达图"
        height="350"
        userBrandData="{{userBrandAnalysis}}"
        comparisonData="{{competitorAnalysis}}"
      />
    </view>

    <!-- 情感对比柱状图 -->
    <view class="chart-card" wx:if="{{competitorAnalysis && competitorAnalysis.length > 0}}">
      <sentiment-bar
        title="品牌情感分布对比"
        height="350"
        sentimentData="{{competitorAnalysis}}"
      />
    </view>
  </view>

  <!-- P1 新增：工作流分析发现 -->
  <view class="section" wx:if="{{workflowResults}}">
    <workflow-findings
      title="工作流分析发现"
      subtitle="AI 诊断过程关键发现"
      workflowStages="{{workflowResults.workflow_stages}}"
      summary="{{workflowResults.summary}}"
      expandAll="{{false}}"
      expandedStage="{{expandedWorkflowStage}}"
      bind:stagetoggle="onWorkflowStageToggle"
    ></workflow-findings>
  </view>

  <!-- 第二段：核心问题诊断分析 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">📊</text>
        <text class="title-text">核心问题诊断分析</text>
      </view>
      <view class="section-subtitle">共 {{questionCards.length}} 个问题</view>
    </view>

    <view class="question-list">
      <block wx:for="{{questionCards}}" wx:key="index">
        <view class="question-card {{item.riskLevel || item.risk_level || 'safe'}}" bindtap="goToQuestionDetail" data-index="{{index}}">
          <view class="q-header">
            <view class="q-number {{item.riskLevel || item.risk_level || 'safe'}}">Q{{index + 1}}</view>
            <text class="q-text">{{item.text || item.question_text}}</text>
            <view class="risk-badge {{item.riskLevel || item.risk_level || 'safe'}}">
              <text class="risk-icon">{{item.riskLevel === 'critical' || item.risk_level === 'critical' ? '🔴' : item.riskLevel === 'warning' || item.risk_level === 'warning' ? '🟠' : item.riskLevel === 'high' || item.risk_level === 'high' ? '🟡' : item.riskLevel === 'mid' || item.risk_level === 'mid' ? '🔵' : '🟢'}}</text>
            </view>
          </view>

          <view class="q-body">
            <view class="q-metrics">
              <view class="q-metric">
                <text class="q-metric-label">平均排名</text>
                <text class="q-metric-value {{(item.avgRank || item.avg_rank) === '未入榜' ? 'unranked' : ''}}">{{item.avgRank || item.avg_rank}}</text>
              </view>
              <view class="q-metric">
                <text class="q-metric-label">提及率</text>
                <text class="q-metric-value">{{item.mentionCount || 0}}/{{item.totalModels || 0}}</text>
                <text class="q-metric-percent">{{item.mentionRate || item.mention_rate || 0}}%</text>
              </view>
              <view class="q-metric">
                <text class="q-metric-label">情感</text>
                <text class="q-metric-value {{(item.avgSentiment || item.avg_sentiment) >= 0.3 ? 'positive' : (item.avgSentiment || item.avg_sentiment) <= -0.3 ? 'negative' : 'neutral'}}">{{item.avgSentiment || item.avg_sentiment}}</text>
              </view>
            </view>

            <view class="q-status {{item.riskLevel || item.risk_level || 'safe'}}">
              <text class="status-icon">{{item.riskLevel === 'critical' || item.risk_level === 'critical' ? '🚨' : item.riskLevel === 'warning' || item.risk_level === 'warning' ? '⚠️' : item.riskLevel === 'high' || item.risk_level === 'high' ? '⚡' : item.riskLevel === 'mid' || item.risk_level === 'mid' ? '📊' : '✅'}}</text>
              <text class="status-text">{{item.riskLevelText || item.risk_level_text || '安全'}}</text>
            </view>
          </view>

          <!-- 竞品拦截详情 -->
          <view class="q-footer" wx:if="{{item.key_competitor || (item.intercepted_by && item.intercepted_by.length > 0)}}">
            <view class="interception-banner">
              <view class="interception-header">
                <text class="interception-icon">🎯</text>
                <text class="interception-title">竞品拦截分析</text>
              </view>
              <view class="key-competitor" wx:if="{{item.key_competitor}}">
                <text class="competitor-label">主要拦截:</text>
                <text class="competitor-name">{{item.key_competitor}}</text>
                <text class="competitor-count">({{item.interceptCount || 0}} 次)</text>
              </view>
              <view class="competitor-list" wx:if="{{item.intercepted_by && item.intercepted_by.length > 1}}">
                <block wx:for="{{item.intercepted_by}}" wx:key="*this" wx:for-item="competitor">
                  <view class="competitor-tag" wx:if="{{competitor !== item.key_competitor}}">
                    <text>{{competitor}}</text>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 第三段：高风险负面信源 -->
  <view class="section" wx:if="{{toxicSources && toxicSources.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">🚨</text>
        <text class="title-text">高风险负面信源</text>
      </view>
      <view class="section-subtitle">共 {{toxicSources.length}} 个危险信源</view>
    </view>

    <view class="toxic-sources-list">
      <block wx:for="{{toxicSources}}" wx:key="url">
        <view class="toxic-source-card threat-{{item.threatLevel || item.threat_level || 'safe'}}" bindtap="onSourceTap" data-source="{{item}}">
          <view class="ts-header">
            <view class="ts-site">
              <text class="ts-site-name">{{item.site_name || item.site}}</text>
              <view class="threat-score-badge {{item.threatLevel || item.threat_level || 'safe'}}">
                <text class="threat-score-label">威胁度</text>
                <text class="threat-score-value">{{item.threat_score || item.threatScore || 0}}</text>
              </view>
            </view>
            <view class="ts-tag negative">负面</view>
          </view>
          <view class="ts-url">{{item.url}}</view>
          <view class="ts-footer">
            <text class="ts-model">提及 {{item.totalMentions || item.total_mentions || 0}} 次</text>
            <text class="ts-impact">影响排名</text>
            <text class="ts-copy">📋 复制链接</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!toxicSources || toxicSources.length === 0}}">
    <view class="empty-icon">✅</view>
    <view class="empty-text">未发现高风险负面信源</view>
    <view class="empty-sub">品牌声誉状况良好</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="btn-secondary" bindtap="viewHistory">📋 历史记录</button>
    <button class="btn-primary" bindtap="exportReport">导出报告</button>
  </view>
</view>

<!-- 加载中状态 -->
<view class="loading-container" wx:elif="{{!loadError}}">
  <view class="loading-spinner"></view>
  <view class="loading-text">正在生成战略看板...</view>
</view>

<!-- 错误状态 -->
<view class="error-container" wx:else>
  <view class="error-icon">⚠️</view>
  <view class="error-title">{{errorType === 'network' ? '网络连接失败' : errorType === 'timeout' ? '请求超时' : '数据加载失败'}}</view>
  <view class="error-text">{{loadError}}</view>
  <view class="error-actions">
    <button class="btn-retry" bindtap="retry">重新加载</button>
    <button class="btn-home" bindtap="goHome">返回首页</button>
  </view>
</view>
